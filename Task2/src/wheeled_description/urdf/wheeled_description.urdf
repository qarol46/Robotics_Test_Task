<?xml version="1.0" encoding="utf-8"?>
<robot name="wheeled_description" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  
  <material name="dark_gray">
    <color rgba="0.153 0.153 0.153 1"/>
  </material>
  
  <material name="light_blue">
    <color rgba="0.792 0.820 0.933 1"/>
  </material>

  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <material name="blue">
    <color rgba="0.2 0.2 0.8 1"/>
  </material>

  <link name="root_link">
    <visual>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <link name="base_link">
    <inertial>
      <origin xyz="0.0008 0 0.1001" rpy="0 0 0"/>
      <mass value="4.5"/>
      <inertia ixx="0.4303" ixy="0" ixz="0.00006" iyy="1.3232" iyz="0" izz="1.4788"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="file://$(find wheeled_description)/meshes/base_link.STL"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file://$(find wheeled_description)/meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="root_to_base" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="root_link"/>
    <child link="base_link"/>
  </joint>

  <link name="fr_wh_link">
    <inertial>
      <origin xyz="0 0.06384 0" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.01111" ixy="0" ixz="0" iyy="0.01738" iyz="0" izz="0.01111"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="file://$(find wheeled_description)/meshes/fr_wh_link.STL"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.13" length="0.12"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/> <!-- Rotate 90° around X -->
    </collision>
  </link>

  <joint name="fr_wh_joint" type="continuous">
    <origin xyz="0.205 -0.32029 -0.02" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="fr_wh_link"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" velocity="10"/>
    <dynamics friction="1.0"/>
  </joint>

  <!-- Front Left Wheel -->
  <link name="fl_wh_link">
    <inertial>
      <origin xyz="0 -0.06384 0" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.01111" ixy="0" ixz="0" iyy="0.01738" iyz="0" izz="0.01111"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="file://$(find wheeled_description)/meshes/fl_wh_link.STL"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.13" length="0.12"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/> <!-- Rotate 90° around X -->
    </collision>
  </link>

  <joint name="fl_wh_joint" type="continuous">
    <origin xyz="0.205 0.32029 -0.02" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="fl_wh_link"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" velocity="10"/>
    <dynamics friction="1.0"/>
  </joint>

  <!-- Rear Left Wheel -->
  <link name="rl_wh_link">
    <inertial>
      <origin xyz="0 -0.06384 0" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.01111" ixy="0" ixz="0" iyy="0.01738" iyz="0" izz="0.01111"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="file://$(find wheeled_description)/meshes/rl_wh_link.STL"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.13" length="0.12"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/> <!-- Rotate 90° around X -->
    </collision>
  </link>

  <joint name="rl_wh_joint" type="continuous">
    <origin xyz="-0.205 0.32029 -0.02" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="rl_wh_link"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" velocity="10"/>
    <dynamics friction="1.0"/>
  </joint>

  <!-- Rear Right Wheel -->
  <link name="rr_wh_link">
    <inertial>
      <origin xyz="0 0.06384 0" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.01111" ixy="0" ixz="0" iyy="0.01738" iyz="0" izz="0.01111"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="file://$(find wheeled_description)/meshes/rr_wh_link.STL"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.13" length="0.12"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/> <!-- Rotate 90° around X -->
    </collision>
  </link>

  <joint name="rr_wh_joint" type="continuous">
    <origin xyz="-0.205 -0.32029 -0.02" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="rr_wh_link"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" velocity="10"/>
    <dynamics friction="1.0"/>
  </joint>

<link name="lidar_link">
  <inertial>
    <origin xyz="0 0 0.03589" rpy="0 0 0"/>
    <mass value="0.25"/>
    <inertia ixx="0.00063" ixy="0" ixz="0" iyy="0.00063" iyz="0" izz="0.00075"/>
  </inertial>
  <visual>
    <geometry>
      <mesh filename="file://$(find wheeled_description)/meshes/lidar_link.STL"/>
    </geometry>
    <material name="light_blue"/>
  </visual>
  <collision>
    <geometry>
      <mesh filename="file://$(find wheeled_description)/meshes/lidar_link.STL"/>
    </geometry>
  </collision>
</link>
     
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.12109 0 0.21171" rpy="0 0 0"/>
  </joint>
     
