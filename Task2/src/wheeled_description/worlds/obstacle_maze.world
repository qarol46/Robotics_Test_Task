        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.7 0.7 1.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0 0 1 1</ambient>
            <diffuse>0 0 1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="obstacle_cube_high_2">
      <static>true</static>
      <pose>1 -3 0.75 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.7 0.7 1.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
