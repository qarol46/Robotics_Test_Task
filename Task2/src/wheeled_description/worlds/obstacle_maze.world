    <!-- Высокие цилиндры -->
    <model name="obstacle_cylinder_high_1">
      <static>true</static>
      <pose>-3 4 0.75 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.4</radius>
              <length>1.5</length>
            </cylinder>
