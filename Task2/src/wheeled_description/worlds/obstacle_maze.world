            <diffuse>0.8 0.4 0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="arch_top">
      <static>true</static>
      <pose>3.85 2 0.8 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>1.2 0.3 0.2</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
