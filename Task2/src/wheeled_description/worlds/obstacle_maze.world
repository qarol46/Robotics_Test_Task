    </model>

    <model name="arch_right">
      <static>true</static>
      <pose>4.2 2 0.4 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.3 0.3 0.8</size>
            </box>
