          </geometry>
          <material>
            <ambient>0 1 1 1</ambient>
            <diffuse>0 1 1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================= ВЫСОКИЕ ПРЕПЯТСТВИЯ (1.5 м) ================= -->
    <!-- Высокие кубы -->
    <model name="obstacle_cube_high_1">
      <static>true</static>
      <pose>-2 -3 0.75 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.7 0.7 1.5</size>
